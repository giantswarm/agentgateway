// Repo-specific Renovate rules. Added as the last `extends` entry of the
// generated renovate.json5 and never touched by devctl align-files.
{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  customManagers: [
    {
      // The controller image tracks the vendored subchart appVersion (via the
      // chart's own template fallback + the vendir chart bump), so it needs no
      // Renovate rule. The data-plane proxy tag has no such fallback and is
      // pinned in values.yaml, so bump it from the marker comment there.
      customType: 'regex',
      managerFilePatterns: [
        'helm/agentgateway/values.yaml',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) registryUrl=(?<registryUrl>\\S+)\\s+tag:\\s*(?<currentValue>\\S+)',
      ],
    },
  ],
  packageRules: [
    {
      // The standalone agentgateway product is on the v1.x line: the chart
      // (cr.agentgateway.dev/charts/agentgateway) and the gsoci-mirrored
      // controller/proxy images track github.com/agentgateway/agentgateway
      // releases (latest v1.3.1). The v2.x tags in cr.agentgateway.dev are the
      // deprecated kgateway-based control plane, a different product. Renovate
      // sees 2.2.1 > 1.3.1 and would bump across products, so cap at < 2.0.0.
      matchPackageNames: [
        'cr.agentgateway.dev/charts/agentgateway',
        'cr.agentgateway.dev/charts/agentgateway-crds',
        'giantswarm/agentgateway',
      ],
      allowedVersions: '< 2.0.0',
    },
  ],
}
